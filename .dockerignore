# Docker ignore for Phantom Network Stack
# Include only necessary files for real Adinkhepra implementation

# Exclude ALL large directories by default
*

# Include Dockerfiles and compose files
!Dockerfile*
!docker-compose*.yml
!prometheus.yml
!init-db.sql

# Include real source code for Adinkhepra lattice
!pkg/adinkra/
!cmd/phantom-node/

# Explicit excludes (in case * doesn't catch everything)
.git/
node_modules/
vendor/
bin/
dist/
build/
souhimbou_ai/
ironbank-upload/
adinkhepra-asaf-ironbank/
adinkhepra-telemetry-server/
tools/
services/
deploy/
aws-govcloud/
data/
models/
docs/
keys/
telemetry-keys/
.venv/
venv/
__pycache__/
.next/
out/
memory/
tests/
scripts/
pkg/
cmd/

# Large files
*.exe
*.dll
*.so
*.dylib
*.db
*.sqlite
*.pt
*.pth
*.pem
*.key
*.log
*.tmp
