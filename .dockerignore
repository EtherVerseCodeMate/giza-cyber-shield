# Docker ignore for Phantom Network Stack
# Include only necessary files for real Adinkhepra implementation

# Exclude ALL large directories by default
*

# Include Dockerfiles and compose files
!Dockerfile*
!docker-compose*.yml
!prometheus.yml
!init-db.sql

# Include source code
!pkg/
!cmd/

# Explicit excludes (large or sensitive items)
.git/
node_modules/
vendor/
bin/
dist/
build/
souhimbou_ai/
ironbank-upload/
adinkhepra-asaf-ironbank/
adinkhepra-telemetry-server/
tools/
services/
deploy/
aws-govcloud/
data/
models/
docs/
keys/
telemetry-keys/
.venv/
venv/
__pycache__/
.next/
out/
memory/
tests/
scripts/

# Large binaries and logs
*.exe
*.dll
*.so
*.dylib
*.db
*.sqlite
*.pt
*.pth
*.pem
*.key
*.log
*.tmp
