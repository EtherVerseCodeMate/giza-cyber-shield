# Docker ignore for Phantom Network Stack
# Exclude everything large - phantom-node builds inline

# Exclude ALL large directories
*

# Only include Dockerfiles and compose files
!Dockerfile*
!docker-compose*.yml
!prometheus.yml
!init-db.sql

# Explicit excludes (in case * doesn't catch everything)
.git/
node_modules/
vendor/
bin/
dist/
build/
souhimbou_ai/
ironbank-upload/
adinkhepra-asaf-ironbank/
adinkhepra-telemetry-server/
tools/
services/
deploy/
aws-govcloud/
data/
models/
docs/
keys/
telemetry-keys/
.venv/
venv/
__pycache__/
.next/
out/
memory/
tests/
scripts/
pkg/
cmd/

# Large files
*.exe
*.dll
*.so
*.dylib
*.db
*.sqlite
*.pt
*.pth
*.pem
*.key
*.log
*.tmp
