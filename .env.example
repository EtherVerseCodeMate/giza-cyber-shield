# ─────────────────────────────────────────────────────────────────────────────
# ASAF by NouchiX — Environment Variables
# Copy this file to .env.local for local dev. Never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (Auth + DB) ──────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key
VITE_SUPABASE_PROJECT_ID=your-project-id

# ── ASAF Backend (Fly.io) ─────────────────────────────────────────────────────
# Your Fly.io app URL, e.g. https://asaf-api.fly.dev
NEXT_PUBLIC_ASAF_API_URL=https://your-app.fly.dev
# API key set in Fly.io secrets (fly secrets set ASAF_API_KEY=...)
NEXT_PUBLIC_ASAF_API_KEY=your-api-key-here
# Optional: onboarding scan profile (e.g. nemoclaw) — sent with trigger-scan metadata
NEXT_PUBLIC_ASAF_SCAN_PROFILE=
# Vite apps (SouHimBou.AI): same purpose as above
VITE_ASAF_SCAN_PROFILE=

# ── ASAF API server (Fly.io / cmd/apiserver) ─────────────────────────────────
# Allow free-tier onboarding scans when telemetry license is not valid (marketing funnel).
# fly secrets set ASAF_ALLOW_EVAL_WITHOUT_LICENSE=true
ASAF_ALLOW_EVAL_WITHOUT_LICENSE=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Server-side only (never expose to frontend)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...

# The price ID for the "Certify" plan ($99/mo subscription)
# Create at: https://dashboard.stripe.com/products → Add product → Add price → recurring $99/mo
# Copy the price ID (starts with price_...)
STRIPE_PRICE_ID=price_...

# ── App URL ───────────────────────────────────────────────────────────────────
# Your production domain — used for Stripe redirect URLs
# Must match what's configured in Vercel and Stripe dashboard
NEXT_PUBLIC_APP_URL=https://adinkhepra.com

# ─────────────────────────────────────────────────────────────────────────────
# Vercel: add all NEXT_PUBLIC_* vars in Project Settings → Environment Variables
# Fly.io: add server-side vars with: fly secrets set KEY=value
# Stripe webhooks: configure at dashboard.stripe.com/webhooks pointing to
#   https://adinkhepra.com/api/checkout/webhook (future — for subscription events)
# ─────────────────────────────────────────────────────────────────────────────
