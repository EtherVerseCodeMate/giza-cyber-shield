# =============================================================================
# KHEPRA PROTOCOL - Vercel Ignore File
# Exclude large directories for Next.js frontend deployment
# =============================================================================

# Go backend (2GB+ vendored deps)
pkg/
cmd/
vendor/
bin/
*.go
go.mod
go.sum

# Python services and ML models
services/
*.py
*.pt
*.pth
*.onnx
models/
.venv/
venv/
__pycache__/

# Large data directories
data/
top_secret_intel/
telemetry-keys/
keys/

# Infrastructure/DevOps
deploy/
aws-govcloud/
*.tf
*.tfstate*
Dockerfile*
docker-compose*

# Other large directories
souhimbou_ai/
adinkhepra-telemetry-server/
tools/
/supabase/
!src/integrations/supabase/

# Documentation
docs/
*.md

# Binaries and artifacts
*.exe
*.dll
*.so
*.tar
*.gz
*.zip

# Dev/IDE files
.env.local
*.log
.git/
.idea/
.vscode/
