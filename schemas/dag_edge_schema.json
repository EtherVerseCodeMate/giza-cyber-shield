{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Khepra DAG Edge Schema",
  "description": "Sacred Geometry-aligned DAG edge definition for Giza Cyber Shield",
  "version": "1.0.0",

  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "description": "Edge ID (hash of from+to+type)"
    },

    "from": {
      "type": "string",
      "description": "Source node ID"
    },

    "to": {
      "type": "string",
      "description": "Target node ID"
    },

    "edge_type": {
      "type": "string",
      "enum": [
        "causes",
        "enables",
        "requires",
        "mitigates",
        "remediates",
        "attests",
        "derives_from",
        "implements",
        "violates",
        "complies_with",
        "spawns",
        "supersedes"
      ],
      "description": "Semantic relationship between nodes"
    },

    "directionality": {
      "type": "string",
      "enum": ["forward", "backward", "bidirectional"],
      "default": "forward",
      "description": "Edge direction (forward=fromŌåÆto, backward=fromŌåÉto, bidirectional=fromŌåöto)"
    },

    "weight": {
      "type": "object",
      "properties": {
        "strength": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 0.5,
          "description": "Relationship strength (0=weak, 1=strong)"
        },
        "confidence": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "default": 1.0,
          "description": "Confidence in relationship (0=uncertain, 1=certain)"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5,
          "default": 3,
          "description": "Processing priority (1=low, 5=critical)"
        }
      },
      "required": ["strength", "confidence"]
    },

    "merkaba_flow": {
      "type": "string",
      "enum": [
        "sun_to_sun",
        "earth_to_earth",
        "sun_to_earth",
        "earth_to_sun",
        "seed_to_any",
        "any_to_seed"
      ],
      "description": "Merkaba polarity flow (threatŌåÆthreat, controlŌåÆcontrol, etc.)"
    },

    "sephirot_path": {
      "type": "object",
      "properties": {
        "from_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Source Sephira level"
        },
        "to_level": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "description": "Target Sephira level"
        },
        "ascends": {
          "type": "boolean",
          "description": "True if edge goes up the Tree of Life (toward Keter)"
        },
        "crosses_pillar": {
          "type": "boolean",
          "description": "True if edge crosses pillars (SeverityŌåöMercy)"
        }
      },
      "required": ["from_level", "to_level", "ascends"]
    },

    "verified": {
      "type": "boolean",
      "default": false,
      "description": "Cryptographically verified relationship"
    },

    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Edge creation timestamp (ISO8601)"
    },

    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "description": "Edge-specific metadata"
    }
  },

  "required": [
    "id",
    "from",
    "to",
    "edge_type",
    "weight",
    "merkaba_flow",
    "sephirot_path",
    "timestamp"
  ],

  "additionalProperties": false
}
